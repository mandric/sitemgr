{
  "permissions": {
    "allow": [
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run dev)",
      "Bash(npm run smgr*)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npx vitest*)",
      "Bash(npx playwright*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx next*)",
      "Bash(npx supabase*)",
      "Bash(supabase *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(vercel *)",
      "Bash(cd web *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(dockerd *)",
      "Bash(docker *)",
      "Bash(sleep *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "deep-project@local-plugins": true,
    "deep-plan@local-plugins": true,
    "deep-implement@local-plugins": true,
    "code-review@local-plugins": true,
    "frontend-design@local-plugins": true,
    "feature-dev@local-plugins": true,
    "ralph-wiggum@local-plugins": true,
    "deep-project@piercelamb-plugins": true,
    "deep-implement@piercelamb-plugins": true,
    "code-review@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "local-plugins": {
      "source": {
        "source": "file",
        "path": ".claude/plugins/.claude-plugin/marketplace.json"
      }
    },
    "piercelamb-plugins": {
      "source": {
        "source": "github",
        "repo": "piercelamb/deep-implement"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  }
}
