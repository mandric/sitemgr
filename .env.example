# Environment Variables Template
# Copy this to .env.production (for deployment) or .env.local (for local dev)
# All .env.* files are gitignored except this example

# Supabase Project Reference
# Get from: https://supabase.com/dashboard/project/[THIS-IS-THE-REF]
SUPABASE_PROJECT_REF=

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Twilio Credentials
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+
