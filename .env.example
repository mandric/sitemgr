# Environment Variables Template
# Copy this to .env.production (for deployment) or .env.local (for local dev)
# All .env.* files are gitignored except this example

# ── Deploy-time only (GitHub Actions / CI) ──────────────────────────
# These are NOT needed by the running web app or edge functions.

# Supabase Access Token (account-level, for CLI: db push, functions deploy)
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Supabase Project Reference
# Get from: https://supabase.com/dashboard/project/[THIS-IS-THE-REF]
SUPABASE_PROJECT_REF=

# Vercel App URL (for smoke tests: smoke_test $VERCEL_APP_URL)
# Also set as a GitHub Actions variable (vars.VERCEL_APP_URL)
VERCEL_APP_URL=https://sitemgr-nine.vercel.app

# Vercel Token (for CI deployment polling and log queries)
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Vercel Project ID
# Get from: Vercel project > Settings > General > Project ID
VERCEL_PROJECT_ID=

# Vercel Team ID (optional, only needed for team-owned projects)
# Get from: Vercel team > Settings > General > Team ID
VERCEL_TEAM_ID=

# ── Runtime (Vercel / Edge Functions) ───────────────────────────────
# These are needed by the web app and/or edge functions at runtime.

# Supabase Project URL (project-level)
# Get from: Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Anon/Publishable Key (project-level, safe for client-side)
# Get from: Project Settings > API > anon/public key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Service Role Key (project-level, server-side only — never expose to client)
# Get from: Project Settings > API > service_role key
SUPABASE_SECRET_KEY=

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Twilio Credentials
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+

# Encryption key for S3 credentials stored at rest
# Generate with: openssl rand -base64 32
# See docs/ENV_VARS.md for key rotation procedure
ENCRYPTION_KEY_CURRENT=

# Previous encryption key — only needed during key rotation
# ENCRYPTION_KEY_PREVIOUS=
