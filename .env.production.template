# Production Environment Variables
# Copy this to .env.production and fill in your actual values
# .env.production is gitignored and won't be committed

# Supabase Project (for local deployment script)
# Get this from: https://supabase.com/dashboard/project/[THIS-IS-THE-REF]
SUPABASE_PROJECT_REF=

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Twilio Credentials
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+

# Notes:
# - The deployment script (./scripts/deploy.sh) will automatically load these
# - These same values should be set as GitHub Secrets for CI/CD deployment
# - Don't commit .env.production to git (it's in .gitignore)
