# Environment variables for the sitemgr web app and CLI.
# For local dev: auto-generated by npm run setup:env (or: source scripts/lib.sh && print_setup_env_vars)
# All .env.* files are gitignored except this example.

# ── Supabase ─────────────────────────────────────────────────────────
# Local dev: auto-populated from supabase status
# Production: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── CLI auth ─────────────────────────────────────────────────────────
# Same Supabase instance in local dev; web app URL in production
SMGR_API_URL=
SMGR_API_KEY=

# ── S3 / Storage ────────────────────────────────────────────────────
# Local dev: auto-populated from supabase status (STORAGE_S3_URL, S3_PROTOCOL_*)
SMGR_S3_ENDPOINT=
S3_ENDPOINT_URL=
SMGR_S3_BUCKET=media
SMGR_S3_REGION=local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── smgr CLI ─────────────────────────────────────────────────────────
SMGR_DEVICE_ID=local-dev
SMGR_AUTO_ENRICH=false

# ── Encryption ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Local dev: auto-generated (ephemeral — local data resets with supabase stop)
# See docs/ENV_VARS.md for production key rotation procedure
ENCRYPTION_KEY_CURRENT=
# ENCRYPTION_KEY_PREVIOUS=    # only needed during key rotation

# ── Webhook service account ─────────────────────────────────────────
WEBHOOK_SERVICE_ACCOUNT_EMAIL=webhook@sitemgr.internal
WEBHOOK_SERVICE_ACCOUNT_PASSWORD=

# ── Optional (API integrations) ─────────────────────────────────────
# ANTHROPIC_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+

# ── Test / Admin only (NOT for app code) ─────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=
