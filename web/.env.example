# ── Supabase ─────────────────────────────────────────────────────────
# Get from: Project Settings > API (or: supabase status -o json for local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — test/admin only, not used by running application
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── S3 / Storage ─────────────────────────────────────────────────────
# For local dev: auto-populated by ./scripts/local-dev.sh print_setup_env_vars
SMGR_S3_ENDPOINT=
SMGR_S3_BUCKET=media
SMGR_S3_REGION=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=

# ── CLI ───────────────────────────────────────────────────────────────
SMGR_API_URL=
SMGR_API_KEY=
SMGR_DEVICE_ID=local-dev
SMGR_AUTO_ENRICH=false

# ── Encryption ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# For local dev: auto-generated by ./scripts/local-dev.sh print_setup_env_vars
# See docs/ENV_VARS.md for key rotation procedure
ENCRYPTION_KEY_CURRENT=

# Previous key — only needed during key rotation
# ENCRYPTION_KEY_PREVIOUS=

# ── Optional ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+
