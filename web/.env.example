# web/.env.example — all environment variables used by sitemgr
#
# Copy relevant vars to web/.env.local and fill in your values.
# `npm run setup:env` generates most vars automatically from a running
# Supabase instance. Add any remaining vars (marked "add manually") by hand.
#
# All .env.* files are gitignored except this one.

# ── Generated by `npm run setup:env` ─────────────────────────────────────────
# These are populated automatically from `supabase status` output.
# Re-run `npm run setup:env` after `supabase start` to refresh them.

# Supabase connection (Next.js app)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key — integration tests + /api/auth/device/approve only.
# Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# CLI → Supabase REST
SITEMGR_API_URL=http://127.0.0.1:54321
SITEMGR_API_KEY=

# S3-compatible storage (Supabase Storage)
S3_ENDPOINT_URL=http://127.0.0.1:54321/storage/v1/s3
SITEMGR_S3_ENDPOINT=http://127.0.0.1:54321/storage/v1/s3
SITEMGR_S3_BUCKET=media
SITEMGR_S3_REGION=local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Encryption key for bucket config secrets (AES-256, base64-encoded 32 bytes).
# Generated fresh by setup:env via: openssl rand -base64 32
# WARNING: regenerating this (re-running setup:env) breaks any already-encrypted
# data in the DB. Back up or note your key before re-running setup.
ENCRYPTION_KEY_CURRENT=

# Webhook service account (created by setup:supabase)
WEBHOOK_SERVICE_ACCOUNT_EMAIL=webhook@sitemgr.internal
WEBHOOK_SERVICE_ACCOUNT_PASSWORD=unused-password-webhook-uses-service-token

# Static local dev defaults (same for everyone)
SITEMGR_WEB_URL=http://localhost:3000
SITEMGR_DEVICE_ID=local-dev
SITEMGR_AUTO_ENRICH=false

# ── Add manually ──────────────────────────────────────────────────────────────
# These are not generated by setup:env. Add them to web/.env.local by hand.

# Anthropic API key — required for web agent chat and E2E browser tests.
# Get yours at console.anthropic.com (Max plan includes API access).
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp / Twilio (production only) ───────────────────────────────────────
# Not needed for local dev or E2E browser tests.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# ── Production only ───────────────────────────────────────────────────────────
# Set via Vercel dashboard or CI secrets. Not used locally.
# See docs/ENV_VARS.md for production setup and key rotation procedure.
#
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# ENCRYPTION_KEY_PREVIOUS=    # during key rotation only
# ENCRYPTION_KEY_NEXT=        # during key rotation only
